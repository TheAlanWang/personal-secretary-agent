# LUCY — environment variables (all optional; copy to .env or export in your shell)
# Precedence: env vars override the local config files in data/.

# ── LLM (Akash / any OpenAI-compatible endpoint) ────────────────────────────
# If unset, falls back to data/llm.json; if neither exists, agents run rule-based.
LLM_BASE_URL=https://api.akashml.com/v1
LLM_MODEL=meta-llama/Llama-3.3-70B-Instruct
LLM_API_KEY=akml-xxxxxxxxxxxxxxxxxxxxxxxx
# Set to 1 to force rule-based agents (smoke.py sets this itself)
#LLM_DISABLED=1

# ── Ingest webhook auth (Nexla → POST /api/ingest) ──────────────────────────
# Fail-closed: without this set, /api/ingest only accepts loopback clients.
# Must match the X-Ingest-Token header configured on the Nexla webhook destination.
INGEST_TOKEN=generate-a-long-random-string

# ── Gmail ────────────────────────────────────────────────────────────────────
# No env vars: connect via the UI (top-right "Connect Gmail" with an app
# password). Credentials are stored locally in data/gmail.json (gitignored).
